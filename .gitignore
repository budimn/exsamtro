# Android
#
# Ignore all files in the build directory.
/android/build/
# Don't ignore the gradle wrapper.
!/android/gradle/wrapper/gradle-wrapper.jar
# Allow committing the signing config files.
!/android/**/key.properties

# Windows
#
# Ignore all files in the build directory.
/windows/build/
# Don't ignore the runner folder.
!/windows/runner/

# Linux
#
# Ignore all files in the build directory.
/linux/build/
# Don't ignore the my_application.cc file.
!/linux/my_application.cc

# macOS
#
# Ignore all files in the build directory.
/macos/build/
# Don't ignore the runner folder.
!/macos/runner/

# Generated files
lib/generated_plugin_registrant.dart
lib/firebase_options.dart
